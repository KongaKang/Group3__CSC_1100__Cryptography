                                        cout << "Do you want to try with a different shift value? \nInput \"Yes\" or \"No\" ";
                                        while (anotherAttempt != "Yes" and anotherAttempt != "yes" and anotherAttempt != "y"
                                    and anotherAttempt != "No" and anotherAttempt != "no" and anotherAttempt != "n") {
                                            cin >> anotherAttempt;
                                            if (anotherAttempt == "Yes" or anotherAttempt == "yes" or anotherAttempt == "y") {
                                                break;
                                            }
                                            else if (anotherAttempt == "No" or anotherAttempt == "no" or anotherAttempt == "n") {
                                                cout << "You have chosen to not try a different shift value." << endl;
                                                isMessageDecoded = true;
                                                break;
                                            }
                                            else {
                                                cout << "Please enter either \"Yes\" or \"No\" ";
                                            }
                                        }
                                    }
                                    else {
                                        cout << "Please enter either \"Yes\" or \"No\" ";
                                    }
                                }
                            }

                            else if (decodeGuess == 13) {
                                cout << "Decoding message using Rot13 Cipher (shift value 13)" << endl;
                                Rot13Cipher rottenCipher;
                                cout << "Encoded message: " << hiddenMessage << endl;
                                cout << "Decoded message: " << currentEncryption.decode(hiddenMessage) << endl;

                                // Ask the user if the decoded message is correct
                                string isMessageCorrect = "Maybe";
                                cout << "Is the decoded message correct?\nInput \"Yes\" or \"No\" ";
                                while (isMessageCorrect != "Yes" and isMessageCorrect != "yes" and isMessageCorrect != "y"
                            and isMessageCorrect != "No" and isMessageCorrect != "no" and isMessageCorrect != "n") {
                                    cin >> isMessageCorrect;
                                    if (isMessageCorrect == "Yes" or isMessageCorrect == "yes" or isMessageCorrect == "y") {
                                        isMessageDecoded = true;
                                        cout << "Congratulations! You decoded the message correctly." << endl;
                                        break;
                                    }
                                    // Ask the user if they wish to make another attempt at the decryption
                                    else if (isMessageCorrect == "No" or isMessageCorrect == "no" or isMessageCorrect == "n") {
                                        string anotherAttempt;
                                        cout << "Do you want to try with a different shift value? \nInput \"Yes\" or \"No\" ";
                                        while (anotherAttempt != "Yes" and anotherAttempt != "yes" and anotherAttempt != "y"
                                    and anotherAttempt != "No" and anotherAttempt != "no" and anotherAttempt != "n") {
                                            cin >> anotherAttempt;
                                            if (anotherAttempt == "Yes" or anotherAttempt == "yes" or anotherAttempt == "y") {
                                                break;
                                            }
                                            else if (anotherAttempt == "No" or anotherAttempt == "no" or anotherAttempt == "n") {
                                                cout << "You have chosen to not try a different shift value." << endl;
                                                isMessageDecoded = true;
                                                break;
                                            }
                                            else {
                                                cout << "Please enter either \"Yes\" or \"No\" ";
