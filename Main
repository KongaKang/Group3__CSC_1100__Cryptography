#include <iostream>
#include <string> 
using namespace std;

class CaesarCipher {
    private:
        int shiftValue;
    protected:
        string encode(const string& message) {
            cout << "";
        };

        for (char c : message ) {
            if (isalpha(c)) {
                char base;
                if (islower(c)) {
                    base = 'a';

                } else {
                    base = 'A';
                }
            }  result += char((c - base + shiftValue) % 26 + base);
            else {
                result += c;// this will leave non letters unchanged 
            }
            return result;
        }

    public:
        void setShiftValue(int value) {
            shiftValue = value;
        }
        string decode(const string& message) {
            int oldShift = shiftValue;

            shiftValue = (26 - shiftValue) % 26;

            string decode = encode (message);
            shiftValue = oldShift;
            return decode;
        }
};


class Rot13Cipher: public CaesarCipher {
    public:
        Rot13Cipher() {
            setShiftValue(13);
        }
};

int main()
{
    // Initialize variables
    string userChoice;
    string keyPhrase;
    int userShiftValue = -1;

    // Ask the user if they are going to encrypt or decrpt a message
    cout << "Would you like to encrypt or decrypt a message?" << endl;
    cout << "Input \"1\" to encrypt a message, or \"2\" to decrypt a message. " << endl;

    while (userChoice != "1" and userChoice != "2") {
        cin >> userChoice;

        if (userChoice == "1") {
            cout << "You have chosen to encrypt a message." << endl;
            cout << "Enter the message to be encoded: ";
            cin >> keyPhrase;
            // Ask the user for a shift value
            cout << "Enter a shift value to encode the message accordingly: ";
            while (userShiftValue < 0 or userShiftValue > 26) {
                cin >> userShiftValue;
                if (userShiftValue > 0 or userShiftValue < 26) {
                    cout << "You have chosen " << userShiftValue << " as your shift value." << endl;
                }
                else {
                    cout << "Please enter a shift value between 1 and 25. ";
                }
            }

            // Ask the user if they wish to decrypt the recently encoded message
            string decodeNow = "Maybe";
            cout <<"Do you want to decode the recently encoded message?\nInput \"Yes\" or \"No\" ";
            while (decodeNow != "Yes" or decodeNow != "No" or decodeNow != "yes" or decodeNow != "no" or decodeNow != "y" or decodeNow != "n") {
                cin >> decodeNow;
                if (decodeNow == "Yes" or decodeNow != "yes" or decodeNow != "y") {
                    cout << "Enter your guess for the shift value (1-13) to decode the message"
                }
                else if (decodeNow == "No" or decodeNow != "no" or decodeNow != "n") {
                    cout << "You have chosen to not decode the message.";
                }
                else {
                    cout << "Please enter \"Yes\" or \"No\"";
                }
                
            }
        }
        else if (userChoice == "2") {
            cout << "You have chosen to decrypt a message." << endl;
            keyPhrase = "SecretMessage";
        }
        else {
            cout << "Please enter \"1\" to encrypt a message, or \"2\" to decrypt a message. ";
        }
    }

    return 0;
}
