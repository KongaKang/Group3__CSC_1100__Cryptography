#include <iostream>
#include <string> 
using namespace std;

class CaesarCipher {
    private:
        int shiftValue;
    protected:
        string encode(const string& message) {
            // Initialize the value which will store the encoded message
            string encodedMessage;

            // Encrypt the message
            for (char c : message ) {
                if (isalpha(c)) {
                    char base;
                    if (islower(c)) {
                        base = 'a';
                    }
                    else {
                        base = 'A';
                    }
                    encodedMessage += char((c - base + shiftValue) % 26 + base);
                }
                
                else {
                    encodedMessage += c;// this will leave non letters unchanged 
                }
            }
            return encodedMessage;
        }

    public:
        // Sets the shift value
        void setShiftValue(int value) {
            shiftValue = value;
        }
        string decode(const string& message) {
            int oldShift = shiftValue;

            shiftValue = (26 - shiftValue) % 26;

            string decoded = encode (message);
            shiftValue = oldShift;
            return decoded;
        }
};


class Rot13Cipher: public CaesarCipher {
    public:
        Rot13Cipher() {
            setShiftValue(13);
        }
};

int main()
{
    // Initialize variables
    string userChoice;
    string keyPhrase;
    int userShiftValue = -1;

    // Ask the user if they are going to encrypt or decrpt a message
    cout << "Would you like to encrypt or decrypt a message?" << endl;
    cout << "Input \"1\" to encrypt a message, or \"2\" to decrypt a message. " << endl;

    while (userChoice != "1" and userChoice != "2") {
        cin >> userChoice;

        if (userChoice == "1") {
            cout << "You have chosen to encrypt a message." << endl;
            cout << "Enter the message to be encoded: ";
            cin >> keyPhrase;
            // Ask the user for a shift value
            cout << "Enter a shift value to encode the message accordingly: ";
            while (userShiftValue < 0 or userShiftValue > 14) {
                cin >> userShiftValue;
                if (userShiftValue > 0 or userShiftValue < 14) {
                    cout << "You have chosen " << userShiftValue << " as your shift value." << endl;
                }
                else {
                    cout << "Please enter a shift value between 1 and 13. ";
                }
            }

            // Generate the encoded message and give it to the user
            CaesarCipher currentEncryption;
            currentEncryption.setShiftValue(userShiftValue);
            hiddenMessage = currentEncryption.encode(keyPhrase);

            // Ask the user if they wish to decrypt the recently encoded message
            string decodeNow = "Maybe";
            cout <<"Do you want to decode the recently encoded message?\nInput \"Yes\" or \"No\" ";
           while (decodeNow != "Yes" && decodeNow != "No" &&
        decodeNow != "yes" && decodeNow != "no" &&
        decodeNow != "y"   && decodeNow != "n") {
                cin >> decodeNow;
                // Ask the user if they wish to decodde the message now
                if (decodeNow == "Yes" or decodeNow != "yes" or decodeNow != "y") {
                    int decodeGuess = -1;
                    // Prompt the user for their shift value guess.
                    cout << "Enter your guess for the shift value (1-13) to decode the message ";
                    while (decodeGuess < 0 or decodeGuess > 14) {
                        cin >> decodeGuess;

                        if (decodeGuess > 0 or decodeGuess < 14) {
                            cout << "Decoding message using Caesar Cipher (shift value " << decodeGuess << "):" << endl;
                            currentEncryption.setShiftValue(decodeGuess);
                            cout << "Encoded message: " << hiddenMessage << endl;
                            cout << "Decoded message: " << currentEncryption.decode(keyPhrase) << endl;
                        }
                        else {
                            cout << "Please enter a value between 1 and 13 ";
                        }
                    }
                }
                else if (decodeNow == "No" or decodeNow != "no" or decodeNow != "n") {
                    cout << "You have chosen to not decode the message.";
                }
                else {
                    cout << "Please enter \"Yes\" or \"No\"";
                }
                
            }
        }

        else if (userChoice == "2") {
            cout << "You have chosen to decrypt a message." << endl;
            cin.ignore();
            cout << "Enter the captured (encoded) message: ";
            getline(cin, keyPhrase);

            bool correct = false;

            while (!correct) {
                int guess;
                cout << "Enter your guess for the shift value (1-13): ";
                cin >> guess;
                
                while(guess < 1 || guess > 13) {
                    cout << "Invalid input. Enter a number between 1 and 13: ";
                    cin >> guess;
                }

                CaesarCipher* decoder = new CaesarCipher();
                decoder->setShiftValue(guess);

                string attempt = decoder->decode(keyPhrase);

                cout << "Decoded message attempt: " << attempt << endl;

                delete decoder;

                string isCorrect;
                cout << "Is the decoded message correct? (Yes/No): ";
                cin >> isCorrect;

                if (isCorrect == "Yes" || isCorrect == "yes" || isCorrect == "y") {
                    cout << "Great job! You decoded the message.\n";
                    correct = true;
                }
                else {
                    string tryAgain;
                    cout << "Try another shift value? (Yes/No): ";
                    cin >> tryAgain;

                    if (tryAgain == "No" || tryAgain == "no" || tryAgain == "n") {
                        cout << "Exiting...\n";
                        break;
                    }
                }
            }
        }

        else {
            cout << "Please enter \"1\" to encrypt a message, or \"2\" to decrypt a message. ";
        }
    }

    return 0;
}
