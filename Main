#include <iostream>
#include <string> 
using namespace std;

class CaesarCipher {
    private:
        int shiftValue;
    protected:
        int string encode(const string& message) {
            cout << "";
        }

        for (char c : message ) {
            if (isalpha(c)) {
                char base;
                if (islower(c)) {
                    base = 'a';

                } else {
                    base = 'A';
                }
            }  result += char((c - base + shiftValue) % 26 + base);
            else {
                result += c;// this will leave non letters unchanged 
            }
        }  return result; 
    public:
        void setShiftValue(int value) {
           shiftValue = value % 26;
        }
        string decode(const string& message) {
           int oldShift = shiftValue;

          shiftValue = (26 - shiftValue) % 26;

          string decode = encode (message);
          shiftValue = oldShift;
          return decode;

        }
};


class Rot13Cipher: public CaesarCipher {
    public:
        Rot13Cipher() {
            setShiftValue(13);
        }
};

int main()
{
    cout << "";

    return 0;
}
