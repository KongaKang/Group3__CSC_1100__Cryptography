                            cout << "Exiting...\n";
                            break;
                        }
                    }
                }

                else {
                    cout << "Decoding message using Rot13 Cipher (shift value " << guess << " )" << endl;

                    Rot13Cipher rottedCipher;

                    CaesarCipher* decoder = new CaesarCipher();
                    decoder->setShiftValue(guess);

                    string attempt = decoder->decode(keyPhrase);

                    cout << "Encoded message: " << keyPhrase << endl;

                    cout << "Decoded message attempt: " << attempt << endl;

                    delete decoder;

                    string isCorrect;
                    cout << "Is the decoded message correct? (Yes/No): ";
                    cin >> isCorrect;

                    while (isCorrect != "Yes" and isCorrect != "yes" and isCorrect != "y" 
                and isCorrect != "No" and isCorrect != "no" and isCorrect != "n") {
                        cout << "Please enter either \"Yes\" or \"No\" ";
                        cin >> isCorrect;
                    }

                    if (isCorrect == "Yes" || isCorrect == "yes" || isCorrect == "y") {
                    cout << "Great job! You decoded the message.\n";
                    correct = true;
                    }
                    else {
                        string tryAgain;
                        cout << "Try another shift value? (Yes/No): ";
                        cin >> tryAgain;

                        while (tryAgain != "Yes" and tryAgain != "yes" and tryAgain != "y" 
                    and tryAgain != "No" and tryAgain != "no" and tryAgain != "n") {
